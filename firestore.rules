rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isCoupleMember() {
      return request.auth != null
        && request.auth.uid in [
          'WgCYHSWWZkRds1CpMaZkp0VEEEv1',
          'rjjpaW7VGOZ52yrNTsdW2bxKDQ62'
        ];
    }

    function isCoupleClimbingReader(uid) {
      return isCoupleMember()
        && uid in [
          'WgCYHSWWZkRds1CpMaZkp0VEEEv1',
          'rjjpaW7VGOZ52yrNTsdW2bxKDQ62'
        ];
    }

    // User doc itself
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Couple comparison can read, but never write, each other's climbing data.
      match /climbing_history/{document} {
        allow read: if isOwner(uid) || isCoupleClimbingReader(uid);
        allow write: if isOwner(uid);
      }

      match /climbing_sessions/{sessionId} {
        allow read: if isOwner(uid) || isCoupleClimbingReader(uid);
        allow write: if isOwner(uid);

        match /climbs/{climbId} {
          allow read: if isOwner(uid) || isCoupleClimbingReader(uid);
          allow write: if isOwner(uid);
        }
      }

      match /meta/climbing_migration {
        allow read: if isOwner(uid) || isCoupleClimbingReader(uid);
        allow write: if isOwner(uid);
      }

      // ALL subcollections under this user (climbing_sessions, climbs, gym_nicknames, meta, etc.)
      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Everything else denied by default
  }
}
